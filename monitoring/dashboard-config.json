{
  "dashboards": [
    {
      "name": "Daily Cost Report",
      "metrics": [
        "daily_cost",
        "cost_by_worker",
        "cost_per_task",
        "savings_vs_baseline"
      ],
      "refresh": "1h"
    },
    {
      "name": "Worker Health",
      "metrics": [
        "latency_by_worker",
        "error_rate_by_worker",
        "cache_hit_rate",
        "uptime"
      ],
      "refresh": "5m"
    },
    {
      "name": "Cost Drivers",
      "metrics": [
        "top_cost_tasks",
        "model_usage",
        "batch_size_impact",
        "cache_effectiveness"
      ],
      "refresh": "1h"
    }
  ]
}
